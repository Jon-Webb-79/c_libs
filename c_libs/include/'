int pop_int_array(int *array, int index, int size) {
	if (index >= size) return 0;
	unsigned char *dst = (unsigned char*)array + index * sizeof(int);
	memmove(dst, dst + sizeof(int), sizeof(int) * (size - index - 1));
	return 1;
}
// --------------------------------------------------------------------------------

